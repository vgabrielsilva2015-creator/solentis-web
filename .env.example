# ==============================================================
# Solentis — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env — ele contém segredos.
# ==============================================================

# Banco de dados (SQLite em desenvolvimento)
# Em produção, substitua pela URL do seu banco (PostgreSQL, etc.)
DATABASE_URL="file:./dev.db"

# Desativa telemetria do Next.js
NEXT_TELEMETRY_DISABLED=1

# Segredo para assinar sessões NextAuth (mínimo 32 caracteres)
# Gere um valor seguro com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio

# URL base da aplicação (sem barra final)
NEXTAUTH_URL=http://localhost:3000

# Envio de e-mail transacional (Resend — https://resend.com)
# Em desenvolvimento, pode ficar vazio: os e-mails são apenas logados no console.
# Em produção, é obrigatória — sem ela, o envio de e-mail lança erro.
RESEND_API_KEY=

# Remetente dos e-mails (precisa ser um domínio verificado no Resend)
# Ex.: "Solentis <nao-responda@seudominio.com>"
EMAIL_FROM=

# Armazenamento de arquivos enviados (fotos de ocorrências/tarefas, manuais).
# Em produção (Vercel): crie um Blob Store no painel da Vercel — a variável
# BLOB_READ_WRITE_TOKEN é injetada automaticamente. Em desenvolvimento, deixe
# vazia: os uploads caem para o disco local (./uploads).
BLOB_READ_WRITE_TOKEN=

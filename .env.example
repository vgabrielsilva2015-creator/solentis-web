# ==============================================================
# Solentis — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env.
# ==============================================================

# Banco de dados (PostgreSQL — Supabase em produção)
# DATABASE_URL: conexão com pooling (pgbouncer). DIRECT_URL: conexão direta (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

NEXT_TELEMETRY_DISABLED=1

# Segredo para assinar sessões NextAuth (mínimo 32 caracteres)
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-um-segredo-longo-e-aleatorio

# URL base da aplicação (sem barra final)
NEXTAUTH_URL=http://localhost:3000

# E-mail transacional (Resend). Vazio em dev = e-mails apenas logados.
# Obrigatório em produção.
RESEND_API_KEY=
EMAIL_FROM=

# Armazenamento de uploads. Em produção (Vercel Blob) é injetado automático.
# Vazio em dev = uploads caem no disco local (./uploads).
BLOB_READ_WRITE_TOKEN=

# Segredo do cron da Vercel (gera turnos diários). Obrigatório em produção:
# sem ele, o endpoint /api/cron/shifts fica fail-closed e o cron não roda.
CRON_SECRET=

# IA de extração de laudos (Google Gemini).
GEMINI_API_KEY=

# Web Push (notificações). Gere o par com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Integração WhatsApp (avisos). Opcional.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
